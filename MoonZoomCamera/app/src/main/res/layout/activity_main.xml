<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Live camera preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== Pixel-style minimal top bar ===== -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnFlash"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_flash"
            android:contentDescription="Flash toggle" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Moon Mode toggle: our stand-in for Samsung's Space Zoom AI -->
        <ToggleButton
            android:id="@+id/btnMoonMode"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:textOn="🌕 MOON"
            android:textOff="🌑 MOON"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:background="@drawable/bg_zoom_chip"
            android:paddingHorizontal="14dp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnSwitchCamera"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_switch_camera"
            android:contentDescription="Switch camera" />
    </LinearLayout>

    <!-- Current zoom ratio readout, big centered text like Samsung shows mid-preview -->
    <TextView
        android:id="@+id/txtZoomReadout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1.0x"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:background="@drawable/bg_zoom_chip"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <!-- ===== Samsung-style zoom pill row ===== -->
    <HorizontalScrollView
        android:id="@+id/zoomScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/modeCarousel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="18dp">

        <LinearLayout
            android:id="@+id/zoomChipContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp" />
            <!-- Zoom chips (UW, 1x, 2x, 3x, 5x, 10x, 30x, 50x, 100x) are added programmatically
                 in MainActivity based on the device's actual supported zoom range. -->
    </HorizontalScrollView>

    <!-- ===== iOS-style mode carousel ===== -->
    <LinearLayout
        android:id="@+id/modeCarousel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/modeVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIDEO"
            android:textColor="@color/mode_text_inactive"
            android:textSize="13sp"
            android:letterSpacing="0.05"
            android:paddingHorizontal="14dp" />

        <TextView
            android:id="@+id/modePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PHOTO"
            android:textColor="@color/mode_text_active"
            android:textStyle="bold"
            android:textSize="13sp"
            android:letterSpacing="0.05"
            android:paddingHorizontal="14dp" />

        <TextView
            android:id="@+id/modePortrait"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PORTRAIT"
            android:textColor="@color/mode_text_inactive"
            android:textSize="13sp"
            android:letterSpacing="0.05"
            android:paddingHorizontal="14dp" />
    </LinearLayout>

    <!-- ===== iOS-style bottom control bar ===== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="110dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/galleryThumb"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_zoom_chip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="32dp"
            android:contentDescription="Gallery" />

        <ImageButton
            android:id="@+id/btnShutter"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:background="@drawable/bg_shutter_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="Shutter" />

        <ImageButton
            android:id="@+id/btnSwitchCameraBottom"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_zoom_chip"
            android:src="@drawable/ic_switch_camera"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="32dp"
            android:contentDescription="Switch camera" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
